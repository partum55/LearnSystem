# Vite frontend environment variables

# API base URL used by the browser (use /api when nginx or Vite proxy handles backend routing)
VITE_API_URL=/api

# AI service base URL (through API gateway by default)
VITE_AI_SERVICE_URL=/api/ai

# Dev server proxy target (used by Vite server proxy for /api)
VITE_API_TARGET=http://localhost:8080

# Optional feature flags
VITE_REQUIRE_UCU_EMAIL=false
VITE_VAPID_PUBLIC_KEY=

# Optional backward-compat aliases (supported by this codebase, but VITE_* is preferred)
# REACT_APP_API_URL=
# REACT_APP_AI_SERVICE_URL=
# REACT_APP_REQUIRE_UCU_EMAIL=
# REACT_APP_VAPID_PUBLIC_KEY=
