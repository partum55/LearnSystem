import React, { useEffect, useState, useCallback, useRef } from 'react';
import { useParams, Link, useNavigate } from 'react-router-dom';
import { useTranslation } from 'react-i18next';
import {
  Header,
  Sidebar,
  Card,
  CardHeader,
  CardBody,
  Button,
  Loading,
  CreateModuleModal,
  CreateAssignmentModal,
  CreateQuizModal,
  AddResourceModal,
  ResourceItem,
  EnrollStudentsModal,
  CourseMembersTab,
} from '../components';
import { useCourseStore } from '../store/courseStore';
import { useAuthStore } from '../store/authStore';
import apiClient from '../api/client';
import {
  AcademicCapIcon,
  DocumentTextIcon,
  UserGroupIcon,
  PlusIcon,
  FolderIcon,
  CheckCircleIcon,
  ClockIcon,
  ChevronDownIcon,
  ChevronUpIcon,
} from '@heroicons/react/24/outline';
import { Module, Assignment, Resource } from '../types';

export const CourseDetail: React.FC = () => {
  const { id } = useParams<{ id: string }>();
  const { t } = useTranslation();
  const { user } = useAuthStore();
  const {
    currentCourse,
    modules,
    assignments,
    fetchCourseById,
    fetchModules,
    fetchAssignments,
  } = useCourseStore();
  const [activeTab, setActiveTab] = useState<'modules' | 'assignments' | 'quizzes' | 'members'>('modules');
  const [showModuleModal, setShowModuleModal] = useState(false);
  const [showAssignmentModal, setShowAssignmentModal] = useState(false);
  const [showQuizModal, setShowQuizModal] = useState(false);
  const [showResourceModal, setShowResourceModal] = useState(false);
  const [showEnrollModal, setShowEnrollModal] = useState(false);
  const [selectedModuleId, setSelectedModuleId] = useState<string | null>(null);
  const [moduleResources, setModuleResources] = useState<Record<string, Resource[]>>({});
  const [expandedModules, setExpandedModules] = useState<Set<string>>(new Set());
  const [loadingResources, setLoadingResources] = useState<Set<string>>(new Set());
  const [membersKey, setMembersKey] = useState(0);
  const [quizzes, setQuizzes] = useState<any[]>([]);
  const [loadingQuizzes, setLoadingQuizzes] = useState(false);
  const [isInitialLoading, setIsInitialLoading] = useState(true);
  const navigate = useNavigate();
  const dataLoadedRef = useRef(false);

  const fetchQuizzes = useCallback(async () => {
    if (!id) return;

    setLoadingQuizzes(true);
    try {
      const response = await apiClient.get(`/assessments/quizzes/?course=${id}`);
      const data = response.data as any;
      const quizzesList = Array.isArray(data) ? data : data.results || [];
      setQuizzes(quizzesList);
    } catch (error) {
      console.error('Failed to fetch quizzes:', error);
    } finally {
      setLoadingQuizzes(false);
    }
  }, [id]);

  useEffect(() => {
    // Prevent loading data multiple times (StrictMode issue)
    if (dataLoadedRef.current) {
      setIsInitialLoading(false);
      return;
    }

    const loadData = async () => {
      if (!id) return;

      try {
        const results = await Promise.allSettled([
          fetchCourseById(id),
          fetchModules(id),
          fetchAssignments(id)
        ]);

        // Check if at least the course loaded successfully
        if (results[0].status === 'rejected') {
          console.error('[CourseDetail] Failed to load course:', results[0].reason);
        }

        // Mark as loaded
        dataLoadedRef.current = true;
      } catch (error) {
        console.error('[CourseDetail] Failed to load course data:', error);
      } finally {
        setIsInitialLoading(false);
      }
    };

    loadData();
    // eslint-disable-next-line react-hooks/exhaustive-deps
  }, [id]);

  // Reset dataLoadedRef when course ID changes
  useEffect(() => {
    dataLoadedRef.current = false;
    setIsInitialLoading(true);
  }, [id]);

  useEffect(() => {
    if (id && activeTab === 'quizzes' && !loadingQuizzes && quizzes.length === 0) {
      fetchQuizzes();
    }
    // eslint-disable-next-line react-hooks/exhaustive-deps
  }, [id, activeTab]);

  const fetchModuleResources = async (moduleId: string) => {
    if (moduleResources[moduleId]) {
      return; // Already loaded
    }

    setLoadingResources(prev => new Set(prev).add(moduleId));
    try {
      const response = await apiClient.get<Resource[] | { results: Resource[] }>(`/courses/resources/?module=${moduleId}`);
      const resources = Array.isArray(response.data) ? response.data : response.data.results;
      setModuleResources(prev => ({ ...prev, [moduleId]: resources }));
    } catch (error) {
      console.error('Failed to fetch resources:', error);
    } finally {
      setLoadingResources(prev => {
        const newSet = new Set(prev);
        newSet.delete(moduleId);
        return newSet;
      });
    }
  };

  const toggleModule = (moduleId: string) => {
    const newExpanded = new Set(expandedModules);
    if (newExpanded.has(moduleId)) {
      newExpanded.delete(moduleId);
    } else {
      newExpanded.add(moduleId);
      fetchModuleResources(moduleId);
    }
    setExpandedModules(newExpanded);
  };

  const handleAddResource = (moduleId: string) => {
    setSelectedModuleId(moduleId);
    setShowResourceModal(true);
  };

  const handleResourceAdded = () => {
    if (selectedModuleId) {
      // Refresh resources for the module
      setModuleResources(prev => {
        const newResources = { ...prev };
        delete newResources[selectedModuleId];
        return newResources;
      });
      fetchModuleResources(selectedModuleId);
    }
  };

  const handleDeleteResource = async (resourceId: string, moduleId: string) => {
    try {
      await apiClient.delete(`/courses/resources/${resourceId}/`);
      // Refresh resources
      setModuleResources(prev => {
        const newResources = { ...prev };
        delete newResources[moduleId];
        return newResources;
      });
      fetchModuleResources(moduleId);
    } catch (error) {
      console.error('Failed to delete resource:', error);
    }
  };

  const handleModuleCreated = () => {
    if (id) {
      fetchModules(id);
    }
  };

  const handleAssignmentCreated = () => {
    if (id) {
      fetchAssignments(id);
    }
  };

  const handleQuizCreated = () => {
    if (id) {
      fetchQuizzes();
    }
  };

  const handleStudentsEnrolled = () => {
    // Refresh the course to update member count
    if (id) {
      fetchCourseById(id);
      setMembersKey(prev => prev + 1);
    }
  };

  // Show loading only during initial load
  if (isInitialLoading) {
    return <Loading />;
  }

  // If course failed to load after initial loading, show error
  if (!currentCourse) {
    return (
      <div className="min-h-screen bg-gray-50 dark:bg-gray-900 flex items-center justify-center">
        <div className="text-center">
          <h2 className="text-2xl font-bold text-gray-900 dark:text-white mb-4">
            {t('courses.notFound')}
          </h2>
          <Link to="/courses">
            <Button>{t('courses.backToCourses')}</Button>
          </Link>
        </div>
      </div>
    );
  }

  const isInstructor = user?.role === 'TEACHER' || user?.role === 'SUPERADMIN';

  const tabs = [
    { id: 'modules', name: t('courses.modules'), icon: FolderIcon },
    { id: 'assignments', name: t('assignments.title'), icon: DocumentTextIcon },
    { id: 'quizzes', name: t('quizzes.title'), icon: DocumentTextIcon },
    { id: 'members', name: t('courses.students'), icon: UserGroupIcon },
  ];

  return (
    <div className="min-h-screen bg-gray-50 dark:bg-gray-900">
      <Header />
      <div className="flex">
        <Sidebar />
        <main className="flex-1 p-8">
          <div className="max-w-7xl mx-auto">
            {/* Course Header */}
            <div className="mb-8">
              <div className="flex items-center text-sm text-gray-500 dark:text-gray-400 mb-4">
                <Link to="/courses" className="hover:text-blue-600 dark:hover:text-blue-400">
                  {t('courses.title')}
                </Link>
                <span className="mx-2">/</span>
                <span>{currentCourse.code}</span>
              </div>

              <Card>
                <CardHeader>
                  <div className="flex justify-between items-start">
                    <div>
                      <div className="flex items-center gap-3 mb-2">
                        <AcademicCapIcon className="h-8 w-8 text-blue-600 dark:text-blue-400" />
                        <h1 className="text-3xl font-bold text-gray-900 dark:text-white">
                          {currentCourse.code}
                        </h1>
                      </div>
                      <h2 className="text-xl text-gray-700 dark:text-gray-300">
                        {currentCourse.title}
                      </h2>
                    </div>
                    {isInstructor && (
                      <div className="flex gap-2">
                        <Button
                          variant="secondary"
                          size="sm"
                          onClick={() => navigate(`/question-bank?course=${id}`)}
                        >
                          {t('questionBank.title')}
                        </Button>
                        <Link to={`/courses/${id}/edit`}>
                          <Button variant="secondary" size="sm">
                            {t('common.edit')}
                          </Button>
                        </Link>
                        <Button size="sm" onClick={() => setShowEnrollModal(true)}>
                          <PlusIcon className="h-4 w-4 mr-1" />
                          {t('courses.enrollStudents')}
                        </Button>
                      </div>
                    )}
                  </div>
                </CardHeader>
                <CardBody>
                  <p className="text-gray-600 dark:text-gray-400">
                    {currentCourse.description}
                  </p>
                  <div className="mt-4 flex gap-6 text-sm">
                    <div>
                      <span className="text-gray-500 dark:text-gray-400">{t('courses.instructor')}:</span>
                      <span className="ml-2 font-medium text-gray-900 dark:text-white">
                        {currentCourse.owner_name || 'Unknown'}
                      </span>
                    </div>
                    {currentCourse.member_count !== undefined && (
                      <div>
                        <span className="text-gray-500 dark:text-gray-400">{t('courses.students')}:</span>
                        <span className="ml-2 font-medium text-gray-900 dark:text-white">
                          {currentCourse.member_count}
                        </span>
                      </div>
                    )}
                  </div>
                </CardBody>
              </Card>
            </div>

            {/* Tabs */}
            <div className="border-b border-gray-200 dark:border-gray-700 mb-6">
              <nav className="flex space-x-8">
                {tabs.map((tab) => (
                  <button
                    key={tab.id}
                    onClick={() => setActiveTab(tab.id as any)}
                    className={`
                      flex items-center py-4 px-1 border-b-2 font-medium text-sm transition-colors
                      ${
                        activeTab === tab.id
                          ? 'border-blue-500 text-blue-600 dark:text-blue-400'
                          : 'border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300 dark:text-gray-400 dark:hover:text-gray-300'
                      }
                    `}
                  >
                    <tab.icon className="h-5 w-5 mr-2" />
                    {tab.name}
                  </button>
                ))}
              </nav>
            </div>

            {/* Tab Content */}
            <div>
              {activeTab === 'modules' && (
                <div className="space-y-4">
                  {isInstructor && (
                    <div className="flex justify-end mb-4">
                      <Button onClick={() => setShowModuleModal(true)}>
                        <PlusIcon className="h-4 w-4 mr-2" />
                        {t('modules.addModule')}
                      </Button>
                    </div>
                  )}
                  {!modules || modules.length === 0 ? (
                    <Card>
                      <CardBody>
                        <p className="text-center text-gray-600 dark:text-gray-400 py-12">
                          {t('modules.noModules')}
                        </p>
                      </CardBody>
                    </Card>
                  ) : (
                    (modules || []).map((module: Module) => {
                      const isExpanded = expandedModules.has(module.id);
                      const resources = moduleResources[module.id] || [];
                      const isLoadingResources = loadingResources.has(module.id);

                      return (
                        <Card key={module.id}>
                          <CardHeader>
                            <div className="flex items-center justify-between">
                              <button
                                onClick={() => toggleModule(module.id)}
                                className="flex items-center gap-3 flex-1 text-left"
                              >
                                {isExpanded ? (
                                  <ChevronUpIcon className="h-5 w-5 text-gray-500 dark:text-gray-400" />
                                ) : (
                                  <ChevronDownIcon className="h-5 w-5 text-gray-500 dark:text-gray-400" />
                                )}
                                <FolderIcon className="h-5 w-5 text-blue-600 dark:text-blue-400" />
                                <div className="flex-1">
                                  <h3 className="text-lg font-semibold text-gray-900 dark:text-white">
                                    {module.title}
                                  </h3>
                                  {module.description && (
                                    <p className="text-sm text-gray-600 dark:text-gray-400 mt-1">
                                      {module.description}
                                    </p>
                                  )}
                                </div>
                              </button>
                              <div className="flex items-center gap-3">
                                {module.is_published && (
                                  <span className="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800 dark:bg-green-900 dark:text-green-200">
                                    <CheckCircleIcon className="h-4 w-4 mr-1" />
                                    {t('common.published')}
                                  </span>
                                )}
                                {isInstructor && (
                                  <Button
                                    variant="secondary"
                                    size="sm"
                                    onClick={() => handleAddResource(module.id)}
                                  >
                                    <PlusIcon className="h-4 w-4 mr-1" />
                                    {t('resources.add')}
                                  </Button>
                                )}
                              </div>
                            </div>
                          </CardHeader>
                          {isExpanded && (
                            <CardBody>
                              {isLoadingResources ? (
                                <div className="text-center py-8">
                                  <Loading />
                                </div>
                              ) : resources.length > 0 ? (
                                <div className="space-y-3">
                                  {resources.map((resource: Resource) => (
                                    <ResourceItem
                                      key={resource.id}
                                      resource={resource}
                                      canEdit={isInstructor}
                                      onDelete={(resourceId) => handleDeleteResource(resourceId, module.id)}
                                    />
                                  ))}
                                </div>
                              ) : (
                                <div className="text-center py-8">
                                  <DocumentTextIcon className="h-12 w-12 text-gray-400 dark:text-gray-600 mx-auto mb-3" />
                                  <p className="text-sm text-gray-500 dark:text-gray-400">
                                    {t('modules.noResources')}
                                  </p>
                                  {isInstructor && (
                                    <Button
                                      variant="secondary"
                                      size="sm"
                                      onClick={() => handleAddResource(module.id)}
                                      className="mt-3"
                                    >
                                      <PlusIcon className="h-4 w-4 mr-1" />
                                      {t('resources.addFirst')}
                                    </Button>
                                  )}
                                </div>
                              )}
                            </CardBody>
                          )}
                        </Card>
                      );
                    })
                  )}
                </div>
              )}

              {activeTab === 'assignments' && (
                <div className="space-y-4">
                  {isInstructor && (
                    <div className="flex justify-end mb-4">
                      <Button onClick={() => setShowAssignmentModal(true)}>
                        <PlusIcon className="h-4 w-4 mr-2" />
                        {t('assignments.createAssignment')}
                      </Button>
                    </div>
                  )}
                  {!assignments || assignments.length === 0 ? (
                    <Card>
                      <CardBody>
                        <p className="text-center text-gray-600 dark:text-gray-400 py-12">
                          {t('assignments.noAssignments')}
                        </p>
                      </CardBody>
                    </Card>
                  ) : (
                    <div className="grid gap-4">
                      {(assignments || []).map((assignment: Assignment) => (
                        <Link key={assignment.id} to={`/assignments/${assignment.id}`}>
                          <Card hoverable>
                            <CardBody>
                              <div className="flex justify-between items-start">
                                <div className="flex-1">
                                  <h3 className="text-lg font-semibold text-gray-900 dark:text-white mb-2">
                                    {assignment.title}
                                  </h3>
                                  <p className="text-sm text-gray-600 dark:text-gray-400 mb-3">
                                    {assignment.description}
                                  </p>
                                  <div className="flex items-center gap-4 text-sm">
                                    <span className="flex items-center text-gray-500 dark:text-gray-400">
                                      <ClockIcon className="h-4 w-4 mr-1" />
                                      {assignment.due_date
                                        ? new Date(assignment.due_date).toLocaleDateString()
                                        : t('assignments.noDueDate')}
                                    </span>
                                    <span className="text-gray-500 dark:text-gray-400">
                                      {assignment.max_points} {t('assignments.points')}
                                    </span>
                                  </div>
                                </div>
                                {assignment.submission && (
                                  <span className="px-3 py-1 text-xs font-medium rounded-full bg-green-100 text-green-800 dark:bg-green-900 dark:text-green-200">
                                    {t('assignments.submitted')}
                                  </span>
                                )}
                              </div>
                            </CardBody>
                          </Card>
                        </Link>
                      ))}
                    </div>
                  )}
                </div>
              )}

              {activeTab === 'quizzes' && (
                <div className="space-y-4">
                  {isInstructor && (
                    <div className="flex justify-end mb-4">
                      <Button onClick={() => setShowQuizModal(true)}>
                        <PlusIcon className="h-4 w-4 mr-2" />
                        {t('quizzes.createQuiz')}
                      </Button>
                    </div>
                  )}
                  {loadingQuizzes ? (
                    <div className="text-center py-8">
                      <Loading />
                    </div>
                  ) : quizzes.length === 0 ? (
                    <Card>
                      <CardBody>
                        <p className="text-center text-gray-600 dark:text-gray-400 py-12">
                          {t('quizzes.noQuizzes')}
                        </p>
                      </CardBody>
                    </Card>
                  ) : (
                    <div className="grid gap-4">
                      {quizzes.map((quiz) => (
                        <Link key={quiz.id} to={`/quizzes/${quiz.id}`}>
                          <Card hoverable>
                            <CardBody>
                              <div className="flex justify-between items-start">
                                <div className="flex-1">
                                  <h3 className="text-lg font-semibold text-gray-900 dark:text-white mb-2">
                                    {quiz.title}
                                  </h3>
                                  <p className="text-sm text-gray-600 dark:text-gray-400 mb-3">
                                    {quiz.description}
                                  </p>
                                  <div className="flex items-center gap-4 text-sm">
                                    <span className="flex items-center text-gray-500 dark:text-gray-400">
                                      <ClockIcon className="h-4 w-4 mr-1" />
                                      {quiz.due_date
                                        ? new Date(quiz.due_date).toLocaleDateString()
                                        : t('quizzes.noDueDate')}
                                    </span>
                                    <span className="text-gray-500 dark:text-gray-400">
                                      {quiz.max_points} {t('quizzes.points')}
                                    </span>
                                  </div>
                                </div>
                                {quiz.submission && (
                                  <span className="px-3 py-1 text-xs font-medium rounded-full bg-green-100 text-green-800 dark:bg-green-900 dark:text-green-200">
                                    {t('quizzes.submitted')}
                                  </span>
                                )}
                              </div>
                            </CardBody>
                          </Card>
                        </Link>
                      ))}
                    </div>
                  )}
                </div>
              )}

              {activeTab === 'members' && (
                <CourseMembersTab
                  key={membersKey}
                  courseId={id!}
                  canManage={isInstructor}
                  onMemberRemoved={handleStudentsEnrolled}
                />
              )}
            </div>
          </div>
        </main>
      </div>

      {/* Modals */}
      {isInstructor && (
        <>
          <CreateModuleModal
            isOpen={showModuleModal}
            onClose={() => setShowModuleModal(false)}
            courseId={id!}
            onModuleCreated={handleModuleCreated}
          />
          <CreateAssignmentModal
            isOpen={showAssignmentModal}
            onClose={() => setShowAssignmentModal(false)}
            courseId={id!}
            onAssignmentCreated={handleAssignmentCreated}
          />
          <CreateQuizModal
            isOpen={showQuizModal}
            onClose={() => setShowQuizModal(false)}
            courseId={id!}
            onQuizCreated={handleQuizCreated}
          />
          {selectedModuleId && (
            <AddResourceModal
              isOpen={showResourceModal}
              onClose={() => {
                setShowResourceModal(false);
                setSelectedModuleId(null);
              }}
              moduleId={selectedModuleId}
              onResourceAdded={handleResourceAdded}
            />
          )}
          <EnrollStudentsModal
            isOpen={showEnrollModal}
            onClose={() => setShowEnrollModal(false)}
            courseId={id!}
            onEnrolled={handleStudentsEnrolled}
          />
        </>
      )}
    </div>
  );
};

export default CourseDetail;
