# LearnSystemUCU E2E Test Configuration
# Copy this file to .env and fill in the values

# Application URLs
BASE_URL=http://localhost:3000
API_URL=http://localhost:8080/api

# Test User Credentials (UCU email required)
TEST_STUDENT_EMAIL=test.student@ucu.edu.ua
TEST_STUDENT_PASSWORD=TestPass123!
TEST_STUDENT_NAME=Test Student

TEST_TEACHER_EMAIL=test.teacher@ucu.edu.ua
TEST_TEACHER_PASSWORD=TestPass123!
TEST_TEACHER_NAME=Test Teacher

TEST_ADMIN_EMAIL=admin@ucu.edu.ua
TEST_ADMIN_PASSWORD=admin123
TEST_ADMIN_NAME=Admin User

# Browser Settings
HEADLESS=false
SLOW_MO=0
BROWSER=chromium
# Options: chromium, firefox, webkit

# Viewport Settings
VIEWPORT_WIDTH=1920
VIEWPORT_HEIGHT=1080

# Timeout Settings (milliseconds)
DEFAULT_TIMEOUT=30000
NAVIGATION_TIMEOUT=60000
EXPECT_TIMEOUT=10000

# Test Data
TEST_COURSE_CODE=TEST-COURSE-001
TEST_QUIZ_TITLE=Sample Quiz for Testing

# Screenshots & Videos
SCREENSHOT_ON_FAILURE=true
VIDEO_ON_FAILURE=true
TRACE_ON_FAILURE=true

# Retry Settings
RETRIES=2

