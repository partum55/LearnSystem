# ==========================================
# LearnSystemUCU - Local Development Environment
# ==========================================
# Copy this to .env and configure for local development
#
# USAGE:
#   cp .env.local .env
#   # Edit .env and add your LLAMA_API_KEY
#   docker compose -f docker-compose.local.yml up --build
#
# ==========================================

# ==========================================
# DATABASE CONFIGURATION
# ==========================================
POSTGRES_DB=lms_db
POSTGRES_USER=lms_user
POSTGRES_PASSWORD=lms_password_local

# ==========================================
# SECURITY (Development Only)
# ==========================================
# DO NOT use this key in production!
JWT_SECRET=local-dev-secret-key-for-jwt-must-be-at-least-256-bits-long-for-hs256-algorithm
JWT_EXPIRATION=86400000

# ==========================================
# AI SERVICE CONFIGURATION
# ==========================================
#
# OPTION 1: Groq (Recommended - Free tier with fast inference)
# Get your API key from: https://console.groq.com/keys
LLAMA_API_URL=https://api.groq.com/openai/v1
LLAMA_API_KEY=your-groq-api-key-here
LLAMA_MODEL=llama-3.3-70b-versatile

# OPTION 2: Together AI
# LLAMA_API_URL=https://api.together.xyz/v1
# LLAMA_API_KEY=your-together-api-key-here
# LLAMA_MODEL=meta-llama/Llama-3-70b-chat-hf

# OPTION 3: OpenAI
# LLAMA_API_URL=https://api.openai.com/v1
# LLAMA_API_KEY=your-openai-api-key-here
# LLAMA_MODEL=gpt-4o-mini

# OPTION 4: Local Ollama (if running Ollama container)
# LLAMA_API_URL=http://ollama:11434/v1
# LLAMA_API_KEY=not-required
# LLAMA_MODEL=llama3

# ==========================================
# FRONTEND CONFIGURATION
# ==========================================
REACT_APP_API_URL=http://localhost:8080/api
REACT_APP_AI_SERVICE_URL=http://localhost:8080/api/ai

# ==========================================
# OPTIONAL SERVICES (Disabled by default)
# ==========================================
# KAFKA_ENABLED=false
# SPRING_MAIL_ENABLED=false

