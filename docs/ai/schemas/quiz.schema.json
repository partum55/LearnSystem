{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lms.example.com/schemas/quiz.schema.json",
  "title": "AI Generated Quiz",
  "type": "object",
  "additionalProperties": false,
  "required": ["title", "description", "timeLimit", "attemptsAllowed", "questions"],
  "properties": {
    "title": { "type": "string", "maxLength": 255, "minLength": 3 },
    "description": { "type": "string", "maxLength": 4000, "minLength": 10 },
    "timeLimit": { "type": "integer", "minimum": 5, "maximum": 180 },
    "attemptsAllowed": { "type": "integer", "minimum": 1, "maximum": 10 },
    "shuffleQuestions": { "type": "boolean" },
    "questions": {
      "type": "array",
      "minItems": 1,
      "maxItems": 50,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["questionText", "questionType", "points"],
        "properties": {
          "questionText": { "type": "string", "maxLength": 2000, "minLength": 5 },
          "questionType": {
            "type": "string",
            "enum": ["MULTIPLE_CHOICE", "TRUE_FALSE", "SHORT_ANSWER", "ESSAY", "MATCHING", "FILL_BLANK", "NUMERICAL", "FORMULA"]
          },
          "points": { "type": "integer", "minimum": 1, "maximum": 100 },
          "answerOptions": {
            "type": "array",
            "minItems": 2,
            "maxItems": 10,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["text", "isCorrect"],
              "properties": {
                "text": { "type": "string", "maxLength": 500, "minLength": 1 },
                "isCorrect": { "type": "boolean" },
                "feedback": { "type": "string", "maxLength": 1000 }
              }
            }
          },
          "correctAnswer": { "type": "string", "maxLength": 1000 },
          "explanation": { "type": "string", "maxLength": 2000 }
        }
      }
    }
  }
}
