{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lms.example.com/schemas/assignment.schema.json",
  "title": "AI Generated Assignment",
  "type": "object",
  "additionalProperties": false,
  "required": ["title", "description", "instructions", "assignmentType", "maxPoints"],
  "properties": {
    "title": { "type": "string", "maxLength": 255, "minLength": 3 },
    "description": { "type": "string", "maxLength": 4000, "minLength": 10 },
    "instructions": { "type": "string", "maxLength": 8000, "minLength": 10 },
    "assignmentType": {
      "type": "string",
      "enum": ["QUIZ", "FILE_UPLOAD", "TEXT", "CODE", "URL", "MANUAL_GRADE", "EXTERNAL"]
    },
    "position": { "type": "integer", "minimum": 0, "maximum": 100 },
    "maxPoints": { "type": "integer", "minimum": 1, "maximum": 1000 },
    "timeLimit": { "type": "integer", "minimum": 5, "maximum": 600 },
    "rubric": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "criteria": {
          "type": "array",
          "minItems": 1,
          "maxItems": 15,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name", "description", "maxPoints", "levels"],
            "properties": {
              "name": { "type": "string", "maxLength": 200, "minLength": 2 },
              "description": { "type": "string", "maxLength": 2000, "minLength": 5 },
              "maxPoints": { "type": "integer", "minimum": 1, "maximum": 1000 },
              "levels": {
                "type": "array",
                "minItems": 2,
                "maxItems": 6,
                "items": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["name", "points", "description"],
                  "properties": {
                    "name": { "type": "string", "maxLength": 100, "minLength": 2 },
                    "points": { "type": "integer", "minimum": 0, "maximum": 1000 },
                    "description": { "type": "string", "maxLength": 1000, "minLength": 5 }
                  }
                }
              }
            }
          }
        }
      }
    },
    "learningObjectives": {
      "type": "array",
      "maxItems": 25,
      "items": { "type": "string", "maxLength": 200, "minLength": 3 }
    },
    "resources": {
      "type": "array",
      "maxItems": 25,
      "items": { "type": "string", "maxLength": 500, "minLength": 3 }
    }
  }
}
