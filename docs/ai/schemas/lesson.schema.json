{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lms.example.com/schemas/lesson.schema.json",
  "title": "AI Generated Lesson (Module)",
  "type": "object",
  "additionalProperties": false,
  "required": ["title", "description", "position", "assignments", "quizzes"],
  "properties": {
    "title": { "type": "string", "maxLength": 255, "minLength": 3 },
    "description": { "type": "string", "maxLength": 5000, "minLength": 10 },
    "position": { "type": "integer", "minimum": 0, "maximum": 100 },
    "assignments": {
      "type": "array",
      "maxItems": 50,
      "items": { "$ref": "assignment.schema.json" }
    },
    "quizzes": {
      "type": "array",
      "maxItems": 50,
      "items": { "$ref": "quiz.schema.json" }
    }
  }
}
