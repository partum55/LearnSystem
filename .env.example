# ==========================================
# LMS Environment Configuration
# ==========================================
# Copy this file to .env and fill in your values

# ==========================================
# DATABASE CONFIGURATION
# ==========================================
POSTGRES_DB=lms_db
POSTGRES_USER=lms_user
POSTGRES_PASSWORD=change-me-in-production

# ==========================================
# SECURITY
# ==========================================
# IMPORTANT: Change this in production! Must be at least 256 bits for HS256
JWT_SECRET=dev-secret-key-change-in-production-must-be-at-least-256-bits-long-for-hs256
JWT_EXPIRATION=86400000

# AES-256-GCM encryption key for user API keys (Base64-encoded 32 bytes)
# Generate with: openssl rand -base64 32
AES_ENCRYPTION_KEY=Y2hhbmdlLW1lLWluLXByb2R1Y3Rpb24tMzItYnl0ZXM=

# Google OAuth (optional; required for Google SSO)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8080/api/auth/oauth2/google/callback
GOOGLE_OAUTH_FRONTEND_SUCCESS_URI=http://localhost:3000/auth/google/callback
GOOGLE_OAUTH_FRONTEND_FAILURE_URI=http://localhost:3000/login
# Comma-separated corporate domains allowed for Google SSO
GOOGLE_OAUTH_ALLOWED_DOMAINS=ucu.edu.ua
# Backward-compatible single-domain variable (optional)
GOOGLE_OAUTH_ALLOWED_DOMAIN=ucu.edu.ua

# Gateway quiz attempts rate limit
QUIZ_ATTEMPT_RATE_LIMIT_REPLENISH_RATE=8
QUIZ_ATTEMPT_RATE_LIMIT_BURST_CAPACITY=12
QUIZ_ATTEMPT_RATE_LIMIT_REQUESTED_TOKENS=1

# ==========================================
# AI SERVICE CONFIGURATION
# ==========================================
# Groq API (Recommended - Free tier available)
# Get your API key from: https://console.groq.com/keys
LLAMA_API_URL=https://api.groq.com/openai/v1
LLAMA_API_KEY=your-groq-api-key-here
LLAMA_MODEL=llama-3.3-70b-versatile

# Alternative AI Providers:
# Together AI: https://api.together.xyz/v1
# OpenAI: https://api.openai.com/v1
# Ollama (local): http://ollama:11434

# Available Models:
# Groq: llama-3.3-70b-versatile, llama-3.1-70b-versatile, mixtral-8x7b-32768
# Together AI: meta-llama/Llama-3-70b-chat-hf
# OpenAI: gpt-4, gpt-3.5-turbo

# ==========================================
# FRONTEND CONFIGURATION
# ==========================================
# Frontend runtime/proxy config lives in frontend/.env(.example)
# VITE_API_URL=/api
# VITE_AI_SERVICE_URL=/api/ai
# VITE_API_TARGET=http://localhost:8080

# ==========================================
# SUPABASE (for production deployment)
# ==========================================
# Only needed when deploying from main branch (production docker-compose.yml)
# See .env.production.example for the full production template
# SUPABASE_DB_HOST=aws-0-us-east-1.pooler.supabase.com
# SUPABASE_DB_PORT=6543
# SUPABASE_DB_NAME=postgres
# SUPABASE_DB_USER=postgres.your-project-ref
# SUPABASE_DB_PASSWORD=your-supabase-db-password

# ==========================================
# OPTIONAL: EMAIL CONFIGURATION
# ==========================================
# SPRING_MAIL_ENABLED=true
# SPRING_MAIL_HOST=smtp.gmail.com
# SPRING_MAIL_PORT=587
# SPRING_MAIL_USERNAME=your-email@gmail.com
# SPRING_MAIL_PASSWORD=your-app-password
