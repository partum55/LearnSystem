# ==========================================
# LearnSystemUCU - Production Environment
# ==========================================
# Copy to .env.production and fill in your values:
#   cp .env.production.example .env.production
#
# Used with: docker compose --env-file .env.production up -d

# ==========================================
# SUPABASE DATABASE
# ==========================================
# Find these in Supabase Dashboard → Settings → Database → Connection string
SUPABASE_DB_HOST=aws-0-us-east-1.pooler.supabase.com
SUPABASE_DB_PORT=6543
SUPABASE_DB_NAME=postgres
SUPABASE_DB_USER=postgres.your-project-ref
SUPABASE_DB_PASSWORD=your-supabase-db-password

# ==========================================
# SECURITY
# ==========================================
# Generate a secure secret:  openssl rand -base64 64
JWT_SECRET=CHANGE-ME-generate-with-openssl-rand-base64-64
JWT_EXPIRATION=86400000

# ==========================================
# AI SERVICE (Groq)
# ==========================================
# Get your key from: https://console.groq.com/keys
LLAMA_API_URL=https://api.groq.com/openai/v1
LLAMA_API_KEY=your-groq-api-key
LLAMA_MODEL=llama-3.3-70b-versatile

# ==========================================
# BOOTSTRAP ADMIN
# ==========================================
# Set to true on FIRST deploy only, then set back to false
BOOTSTRAP_ADMIN_ENABLED=false
BOOTSTRAP_ADMIN_EMAIL=admin@ucu.edu.ua
BOOTSTRAP_ADMIN_PASSWORD=change-me-strong-password
