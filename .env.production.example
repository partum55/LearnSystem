# ==========================================
# LearnSystemUCU - Production Environment
# ==========================================
# Copy to .env.production and fill in your values:
#   cp .env.production.example .env.production
#
# Used with: docker compose --env-file .env.production up -d

# ==========================================
# SUPABASE DATABASE
# ==========================================
# Find these in Supabase Dashboard → Settings → Database → Connection string
SUPABASE_DB_HOST=aws-0-us-east-1.pooler.supabase.com
SUPABASE_DB_PORT=6543
SUPABASE_DB_NAME=postgres
SUPABASE_DB_USER=postgres.your-project-ref
SUPABASE_DB_PASSWORD=your-supabase-db-password

# ==========================================
# SECURITY
# ==========================================
# Generate a secure secret:  openssl rand -base64 64
JWT_SECRET=CHANGE-ME-generate-with-openssl-rand-base64-64
JWT_EXPIRATION=86400000

# Google OAuth (university SSO)
GOOGLE_OAUTH_CLIENT_ID=your-google-oauth-client-id
GOOGLE_OAUTH_CLIENT_SECRET=your-google-oauth-client-secret
# Must match Google Console authorized redirect URI
GOOGLE_OAUTH_REDIRECT_URI=https://api.your-domain.com/api/auth/oauth2/google/callback
GOOGLE_OAUTH_FRONTEND_SUCCESS_URI=https://your-app.vercel.app/auth/google/callback
GOOGLE_OAUTH_FRONTEND_FAILURE_URI=https://your-app.vercel.app/login
# Comma-separated corporate domains allowed for Google SSO
GOOGLE_OAUTH_ALLOWED_DOMAINS=ucu.edu.ua
# Backward-compatible single-domain variable (optional)
GOOGLE_OAUTH_ALLOWED_DOMAIN=ucu.edu.ua

# Gateway quiz attempts rate limit
QUIZ_ATTEMPT_RATE_LIMIT_REPLENISH_RATE=8
QUIZ_ATTEMPT_RATE_LIMIT_BURST_CAPACITY=12
QUIZ_ATTEMPT_RATE_LIMIT_REQUESTED_TOKENS=1

# ==========================================
# AI SERVICE (Groq)
# ==========================================
# Get your key from: https://console.groq.com/keys
LLAMA_API_URL=https://api.groq.com/openai/v1
LLAMA_API_KEY=your-groq-api-key
LLAMA_MODEL=llama-3.3-70b-versatile

# ==========================================
# BOOTSTRAP ADMIN
# ==========================================
# Set to true on FIRST deploy only, then set back to false
BOOTSTRAP_ADMIN_ENABLED=false
BOOTSTRAP_ADMIN_EMAIL=admin@ucu.edu.ua
BOOTSTRAP_ADMIN_PASSWORD=change-me-strong-password

# ==========================================
# CORS (required when frontend is on Vercel)
# ==========================================
# Comma-separated list of allowed frontend origins. No trailing slash.
# Add your Vercel URL + any custom domain you set up.
# Example: https://learnsystem.vercel.app,https://lms.yourdomain.com
GATEWAY_CORS_ALLOWED_ORIGINS=https://your-app.vercel.app
